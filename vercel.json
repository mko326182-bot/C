{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "cron/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/cron/(.*)",
      "dest": "cron/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/translation-processor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/cron/title-gen-processor",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/cron/title-extractor-processor",
      "schedule": "*/15 * * * *"
    }
  ]
}