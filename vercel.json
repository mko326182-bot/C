{
  "version": 2,
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "backend/cron/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/backend/cron/tranlation-processor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/backend/cron/title-gen-processor",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/backend/cron/title-extractor-processor",
      "schedule": "*/15 * * * *"
    }
  ]
}